<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nathanieldavis.paper-trading</string>

    <!--
        Pre-stage data that doesn't depend on the midnight-UTC Binance close
        (macros, CoinMetrics, HL instruments, Binance OI/LSR, premium index,
        volume tail). Runs daily ahead of the automated 00:05 UTC full
        advisory run (com.nathanieldavis.paper-trading-full) so the full run
        can pass --skip-prestage and avoid duplicate work.

        Previously ran `daily_paper_run.py --non-binance-only --notify`,
        which only touched 3 of the 6 prestage outputs — `--non-binance-only`
        explicitly skips Binance-derived steps (OI/LSR, volume, premium) at
        `_oi_lsr_step` etc. in daily_paper_run.py. As a result OI never got
        refreshed by the aux flow, and the full run's freshness check
        correctly fell back to a full prestage on every fire. Switched to
        `prestage_daily.py` — which is purpose-built for this — so all 6
        outputs are touched and --skip-prestage actually fires.
    -->
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/opt/python@3.10/bin/python3.10</string>
        <string>/Users/nathanieldavis/pysystemtrade-crypto-perps/scripts/prestage_daily.py</string>
        <string>--config</string>
        <string>/Users/nathanieldavis/pysystemtrade-crypto-perps/config/crypto_perps_1k.yaml</string>
        <string>--env</string>
        <string>dev</string>
    </array>

    <!--
        TZ=UTC is exported into the running script so date strings in logs are UTC,
        but it does NOT affect when launchd schedules the job — see comment on
        StartCalendarInterval below.
    -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>TZ</key>
        <string>UTC</string>
    </dict>

    <!--
        macOS launchd evaluates StartCalendarInterval in SYSTEM LOCAL TIME, not
        the TZ env var. System tz is America/New_York, so:
            Hour=15 → fires at 15:00 EDT (= 19:00 UTC) during DST,
                       and 15:00 EST (= 20:00 UTC) during winter.

        We accept the 1-hour drift between EDT/EST. Moved from 18:00 to 15:00
        on 2026-05-16 to keep the aux refresh comfortably clear of the new
        automated full-run plist (com.nathanieldavis.paper-trading-full),
        which fires at 19:05 EST / 20:05 EDT. With a typical aux duration of
        5-15 min (and occasional 2h+ outliers on slow-API days), 3 hours of
        headroom keeps the aux refresh out of the full run's way even on
        bad days.
    -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>15</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/nathanieldavis/pysystemtrade-crypto-perps/live/launchd_stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/nathanieldavis/pysystemtrade-crypto-perps/live/launchd_stderr.log</string>

    <!-- Do not fire immediately on load — wait for next scheduled time. -->
    <key>RunAtLoad</key>
    <false/>

    <!-- Do not restart if it exits — daily one-shot. -->
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
