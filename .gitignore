# Data directory policy
# Ignore all raw data
data/raw/**

# Ignore all parquet files by default
data/**/*.parquet

# Explicitly allow metadata (negation must come after broader ignore)
!data/raw/
!data/raw/metadata/
!data/raw/metadata/**

# Explicitly allow tracked datasets
!data/example_crypto_perps.parquet
!data/test_fixtures/
!data/test_fixtures/*.parquet

# Temporary files
*.tmp
